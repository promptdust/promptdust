{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PromptDust",
  "version": "0.3.1",
  "identifier": "com.promptdust.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "PromptDust",
        "width": 940,
        "height": 720,
        "minWidth": 640,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage", "dmg", "app", "nsis", "msi"],
    "createUpdaterArtifacts": true,
    "category": "Utility",
    "shortDescription": "Read-only AI-data footprint scanner",
    "longDescription": "Shows where AI tools store conversations, caches, and credentials on this machine, and what amplifies the exposure. Read-only, local-only, never a verdict.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/promptdust/promptdust/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZCNjVCQzZDQTJCNkRDNDYKUldSRzNMYWliTHhsKzVUeGVIVkdkb0c3V29JQ3E2UXBIOHA5aDdSZUM5cTYzYWJaVUpJNjErZDUK"
    }
  }
}
